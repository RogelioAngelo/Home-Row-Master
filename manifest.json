{
  "manifest_version": 3,
  "name": "Home Row Master",
  "version": "1.0.0",
  "description": "Master the home row keys (ASDF GHJ KL;) with this fast-paced typing trainer. Track your speed, accuracy, and streak!",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Home Row Master",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
